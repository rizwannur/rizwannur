# Salt used when hashing visitor IPs for analytics dedup.
# Must be ≥32 chars. Set on every environment (local, preview, prod).
# Rotating invalidates unique-visitor counts across the rotation.
PAYLOAD_IP_SALT=

# ── MCP server auth ──────────────────────────────────────────────────────
# Static bearer for stdio clients (Cursor, Claude Desktop via mcp-remote).
# Generate: openssl rand -base64 48
# Mark Sensitive in Vercel. Never commit. Never log.
MCP_SECRET=

# Public URL of the MCP endpoint — must match Resource Indicator added in
# WorkOS Dashboard → Connect → Configuration → MCP Resource Indicators.
MCP_RESOURCE_URL=https://rizwannur.com/mcp

# WorkOS AuthKit domain (no trailing slash). Found at
# Authentication → Domains in the WorkOS dashboard.
# Staging example: https://vogue-jewel-50-staging.authkit.app
WORKOS_AUTHKIT_DOMAIN=
